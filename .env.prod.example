# Runtime
APP_NAME=TasteScout Agent
APP_ENV=production
API_V1_PREFIX=/api/v1
DEBUG=false
BACKEND_CORS_ORIGINS=["*"]

# Python package mirror for Docker build
PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
PIP_TRUSTED_HOST=mirrors.aliyun.com

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=tastescout

# Backend database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:change_me@postgres:5432/tastescout
SYNC_DATABASE_URL=postgresql://postgres:change_me@postgres:5432/tastescout

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# MCP Proxy
AMAP_MCP_URL=https://mcp.amap.com/mcp?key=your_amap_mcp_key
AMAP_MCP_PROXY_URL=http://amap-mcp-proxy:8010
MCP_TIMEOUT_SECONDS=30

# LLM
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your_dashscope_key
LLM_MODEL=qwen-plus
LLM_TIMEOUT_SECONDS=120
AGENT_TOOL_MODE=function_calling

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://your_server_ip:8000/api/v1
NEXT_PUBLIC_AMAP_JS_KEY=your_amap_js_key
