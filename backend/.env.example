APP_NAME="TasteScout Agent"
APP_ENV="dev"
API_V1_PREFIX="/api/v1"
DEBUG=true
BACKEND_CORS_ORIGINS=["*"]

POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=12345678
POSTGRES_DB=tastescout
DATABASE_URL="postgresql+asyncpg://postgres:12345678@localhost:5432/tastescout"

REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL="redis://localhost:6379/0"


AMAP_MCP_PROXY_URL=http://127.0.0.1:8010
MCP_TIMEOUT_SECONDS=15

LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your_dashscope_key
LLM_MODEL=qwen-plus
LLM_TIMEOUT_SECONDS=30
AGENT_TOOL_MODE=function_calling
